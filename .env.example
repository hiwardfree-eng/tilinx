# ─── Required ───────────────────────────────────────
TilinX_BOT_TOKEN=8602901015:AAF6RWuaurtKU6jPK-rWD856YumQz8cBr40
TilinX_ADMIN_ID=0

# ─── Paths (defaults = auto) ────────────────────────
# TilinX_BASE_DIR=/opt/tilinx
# TilinX_DB_PATH=/opt/tilinx/ips.json
# TilinX_DATA_DIR=/opt/tilinx/data/TilinX
# TilinX_LOG_DIR=/opt/tilinx/logs
# TilinX_KEYS_PATH=/opt/tilinx/keys.json

# ─── Proxy ──────────────────────────────────────────
TilinX_PROXY_PORT=8884
TilinX_PROXY_AUTH_USER=TilinX
TilinX_PROXY_AUTH_PASS=TilinX

# ─── Outbound proxy (optional upstream SOCKS5/HTTP) ─
# TilinX_PROXY_ENABLED=0
# TilinX_PROXY_URL=socks5://user:pass@1.2.3.4:1080
# TilinX_PROXY_TYPE=socks5   # socks5 | http | https

# ─── Security ───────────────────────────────────────
TilinX_ENV=production
TilinX_RATE_LIMIT=10
TilinX_SESSION_TIMEOUT=1800
TilinX_MAX_LOGIN_ATTEMPTS=5
TilinX_LOGIN_BLOCK_MINUTES=15
TilinX_ADMIN_IP_WHITELIST=
TilinX_ADMIN_IP_BIND=0
TilinX_CORS_ORIGIN=https://tilinx.onrender.com
TilinX_CSRF_ENABLED=1
TilinX_ENCRYPT_DB=0
# TilinX_DB_KEY=TilinX_S3cur3_D4t4b4s3_K3y_2026!

# ─── Web ────────────────────────────────────────────
# TilinX_WEB_PORT=8080
# TilinX_WEB_SECRET=
# TilinX_DASH_PASSWORD=
