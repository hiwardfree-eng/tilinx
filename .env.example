# ─── TilinX Configuration ─────────────────────────────────────
# Copy this to .env and fill in your values:
#   cp .env.example .env && nano .env
#
# All vars have defaults, but BOT_TOKEN and ADMIN_ID are REQUIRED
# for Telegram bot + alerts to work.

# ─── Telegram ────────────────────────────────────────────
TilinX_BOT_TOKEN=""
TilinX_ADMIN_ID=0
TilinX_BOT_ENABLED=1

# ─── Proxy ───────────────────────────────────────────────
TilinX_PROXY_PORT=8884
TilinX_PROXY_ENABLED=0          # Set to "1" if using upstream proxy (SOCKS5/HTTP)
TilinX_PROXY_URL=""             # socks5://user:pass@host:port
TilinX_PROXY_TYPE=socks5        # socks5, http, https
TilinX_PROXY_AUTH_USER=TilinX
TilinX_PROXY_AUTH_PASS=TilinX

# ─── Public endpoint (visible to users) ──────────────────
TilinX_PROXY_PUBLIC_HOST="tilinxproxy.duckdns.org"
TilinX_PROXY_PUBLIC_PORT=8884
TilinX_PROXY_PUBLIC_IP=""       # Optional: override with direct IP

# ─── Web Dashboard ───────────────────────────────────────
TilinX_WEB_PORT=8080
TilinX_PUBLIC_BASE_URL="https://tilinx.onrender.com"
TilinX_WEB_SECRET=""            # Auto-generated if empty

# ─── Security ────────────────────────────────────────────
TilinX_RATE_LIMIT=10            # Requests/min/IP
TilinX_MAX_LOGIN_ATTEMPTS=5
TilinX_LOGIN_BLOCK_MINUTES=15
TilinX_ADMIN_IP_WHITELIST=""    # Comma-separated IPs
TilinX_ADMIN_IP_BIND=0          # Bind admin to whitelist only
TilinX_ENV=production
TilinX_CSRF_ENABLED=1
TilinX_ENCRYPT_DB=1
TilinX_JWT_SECRET=""            # Auto-generated if empty
TilinX_CORS_ORIGIN="https://tilinx.onrender.com"

# ─── Admin ───────────────────────────────────────────────
TilinX_ADMIN_USER=tilinX

# ─── GeoIP ───────────────────────────────────────────────
TilinX_GEOIP_ENABLED=0          # Requires internet (ip-api.com)
TilinX_GEOIP_API="http://ip-api.com/json/"

# ─── Database (PostgreSQL / Supabase) ────────────────────
SUPABASE_ENABLED=0
SUPABASE_URL=""
SUPABASE_KEY=""
SUPABASE_DB_HOST=""
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME="postgres"
SUPABASE_DB_USER="postgres"
SUPABASE_DB_PASSWORD=""

# ─── Logging ─────────────────────────────────────────────
TilinX_JSON_LOG=0               # Set to "1" for JSON log format
